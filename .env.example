# ART BANK Platform Environment Variables

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=./artbank.db

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Yandex.Kassa Configuration (Optional)
YANDEX_KASSA_SHOP_ID=your_shop_id
YANDEX_KASSA_SECRET_KEY=your_secret_key

# OAuth Configuration (Optional)
OAUTH_SERVER_URL=

# Vite Environment Variables (Frontend)
VITE_APP_LOGO=/logo.png
VITE_APP_TITLE=ART BANK Platform
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Session Secret (for production)
SESSION_SECRET=change_this_to_a_random_string_in_production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (Optional but recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@artbank.market
FROM_NAME=ART BANK Platform
ADMIN_EMAIL=admin@artbank.market

# AWS S3 Configuration (Optional - for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudflare R2 Configuration (Recommended for file uploads)
# Get your credentials from: https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=artbank-uploads
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# Custom domain (optional): https://uploads.artbank.market

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Cloudflare Configuration (for production deployment)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
